# ============================================================
# API Keys — 只需填写你使用的 provider 对应的 key
# 复制此文件为 .env 并填入你的 key:  cp .env.example .env
# ============================================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o 等)
OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# 阿里云通义千问 (DashScope)
DASHSCOPE_API_KEY=

# Ollama 本地运行无需 key
